---
layout: base.njk
---
<article class="post">
  <p class="eyebrow">Writing</p>
  <h1 class="post-title">{{ title }}</h1>
  <p class="post-date">{{ date | dateDisplay }}</p>
  <div class="post-body">
    {{ content | safe }}
  </div>
  <a class="btn btn-outline" href="/writing/">&larr; Back to all writing</a>
</article>
