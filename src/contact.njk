---
layout: base.njk
title: Contact — Manu Arya
permalink: /contact/
---
<section class="page-hero">
  <p class="eyebrow">Contact</p>
  <h1 class="page-hero-title">{{ contact.headline }}</h1>
  <p class="hero-sub">{{ contact.subhead }}</p>
</section>

<section class="contact-grid">
  <a class="contact-block" href="mailto:{{ contact.email }}">
    <span class="contact-label">Email</span>
    <span class="contact-value">{{ contact.email }}</span>
  </a>

  {% if contact.phone %}
  <a class="contact-block" href="tel:{{ contact.phone }}">
    <span class="contact-label">Phone</span>
    <span class="contact-value">{{ contact.phone }}</span>
  </a>
  {% endif %}

  <div class="contact-block">
    <span class="contact-label">Location</span>
    <span class="contact-value">{{ contact.location }}</span>
  </div>

  {% for s in contact.socials %}
    {% if s.url %}
    <a class="contact-block" href="{{ s.url }}" target="_blank" rel="noopener">
      <span class="contact-label">{{ s.label }}</span>
      <span class="contact-value">Visit &rarr;</span>
    </a>
    {% endif %}
  {% endfor %}
</section>

<section class="contact-form-wrap">
  <p class="section-label">Or send a note directly</p>
  <!-- Netlify Forms: works automatically once deployed on Netlify -->
  <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="contact-form">
    <input type="hidden" name="form-name" value="contact">
    <p class="hidden-field"><label>Don't fill this out: <input name="bot-field"></label></p>
    <label>
      Name
      <input type="text" name="name" required>
    </label>
    <label>
      Email
      <input type="email" name="email" required>
    </label>
    <label>
      Message
      <textarea name="message" rows="5" required></textarea>
    </label>
    <button type="submit" class="btn btn-primary">Send &rarr;</button>
  </form>
</section>
