---
layout: base.njk
title: Manu Arya — Product & Strategy Consultant, Startup Investor
---
<section class="hero">
  <p class="eyebrow">{{ home.eyebrow }}</p>
  <h1 class="hero-title">{{ home.headline | replace("\n", "<br>") | safe }}</h1>
  <p class="hero-sub">{{ home.subhead }}</p>
  <a class="btn btn-primary" href="{{ home.cta_url }}">{{ home.cta_label }} &rarr;</a>
</section>

<section class="stats">
  {% for h in home.highlights %}
  <div class="stat">
    <div class="stat-num">{{ h.stat }}</div>
    <div class="stat-label">{{ h.label }}</div>
  </div>
  {% endfor %}
</section>

<section class="featured">
  <p class="section-label">{{ home.featured_intro }}</p>
  <div class="project-grid">
    {% for project in collections.projects %}
    <a class="project-card" href="/work/#{{ project.fileSlug }}">
      <div class="project-card-image" style="background-image:url('{{ project.data.image }}')"></div>
      <div class="project-card-body">
        <span class="project-tag">{{ project.data.tag }}</span>
        <h3>{{ project.data.title }}</h3>
        <p>{{ project.data.summary }}</p>
      </div>
    </a>
    {% endfor %}
  </div>
</section>

<section class="cta-band">
  <h2>Have a product, a deal, or a project in mind?</h2>
  <a class="btn btn-outline" href="/contact/">Get in touch &rarr;</a>
</section>
